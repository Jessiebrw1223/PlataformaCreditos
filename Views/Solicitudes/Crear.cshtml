@model PlataformaCreditos.ViewModels.CrearSolicitudViewModel

@{
    ViewData["Title"] = "Registrar solicitud";
}

<h1 class="h3 mb-3">Registrar solicitud de crédito</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="MontoSolicitado" class="form-label"></label>
                <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" min="0.01" placeholder="Ejemplo: 5000" />
                <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
                <div class="form-text">El monto no puede superar 10 veces tus ingresos mensuales.</div>
            </div>

            <button type="submit" class="btn btn-primary">Enviar solicitud</button>
            <a asp-action="MisSolicitudes" class="btn btn-outline-secondary">Volver</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
