<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PlataformaCreditos</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var ultimaSolicitudId = Context.Session.GetInt32("UltimaSolicitudId");
    var ultimaSolicitudMonto = Context.Session.GetString("UltimaSolicitudMonto");
}
<header>
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Solicitudes" asp-action="MisSolicitudes">Plataforma Créditos</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Solicitudes" asp-action="MisSolicitudes">Mis solicitudes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Solicitudes" asp-action="Crear">Nueva solicitud</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Analista" asp-action="Index">Panel Analista</a>
                    </li>
                    @if (ultimaSolicitudId.HasValue)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-primary fw-semibold" asp-controller="Solicitudes" asp-action="Detalle" asp-route-id="@ultimaSolicitudId">
                                Ver última solicitud S/ @ultimaSolicitudMonto
                            </a>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Plataforma Créditos
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
